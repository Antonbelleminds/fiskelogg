{
  "name": "FiskeLogg",
  "short_name": "FiskeLogg",
  "description": "Din digitala fiskeloggbok med AI-analys",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#E8DCC4",
  "theme_color": "#0B3B5C",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "permissions": [
    "camera",
    "geolocation"
  ]
}
